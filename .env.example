# Agent runtime
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=high
AGENT_USE_OPENAI=1
AGENT_USE_MCP=1
MCP_BASE_URL=http://127.0.0.1:8000/mcp

# Payment rail: simulator (default) or stripe
PAYMENT_PROVIDER=simulator
# Required only for PAYMENT_PROVIDER=stripe. Test-mode keys only.
STRIPE_SECRET_KEY=
# Safe browser key used by Stripe Elements. Required for interactive card entry.
STRIPE_PUBLISHABLE_KEY=
STRIPE_PAYMENT_METHOD=pm_card_visa
STRIPE_DECLINE_PAYMENT_METHOD=pm_card_visa_chargeDeclined
STRIPE_API_BASE=https://api.stripe.com/v1
STRIPE_TIMEOUT_SECONDS=10
