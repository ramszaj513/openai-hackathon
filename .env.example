# Copy this file to .env and paste a real server-side OpenAI API key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=high

# Live browser speech-to-text through the OpenAI Realtime API.
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_TRANSCRIPTION_LANGUAGE=pl
OPENAI_TRANSCRIPTION_DELAY=low

# Local application wiring.
MCP_BASE_URL=http://127.0.0.1:8000/mcp
AGENT_USE_OPENAI=1
AGENT_USE_MCP=1
PAYMENT_PROVIDER=simulator
DATABASE_URL=sqlite:///./runtime/agent-commerce.db
APP_ENV=development

# Keep model and tool payloads out of Agents SDK logs and traces.
OPENAI_AGENTS_TRACE_INCLUDE_SENSITIVE_DATA=0
OPENAI_AGENTS_DONT_LOG_MODEL_DATA=1
OPENAI_AGENTS_DONT_LOG_TOOL_DATA=1
